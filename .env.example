# ─────────────────────────────────────────────────────────────
# Inkora environment config
# Copy to .env — the defaults below work for local development.
# Supabase keys are OPTIONAL (only needed for accounts & leaderboard).
# ─────────────────────────────────────────────────────────────

# ── Client (Vite) ──
VITE_SOCKET_URL=http://localhost:3001
VITE_SERVER_URL=http://localhost:3001
# Optional — leave blank to play without accounts/leaderboard
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Server ──
PORT=3001
CORS_ORIGIN=http://localhost:5173
# Optional — required only for saving game results to the leaderboard
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Note: voice chat uses the public PeerJS cloud by default — no setup needed.
